# Copiez ce fichier en ".env" avant de démarrer le serveur : cp .env.example .env
# Ne commitez JAMAIS votre vrai fichier .env dans un dépôt public.

# Port d'écoute du serveur
PORT=3000

# Clé secrète utilisée pour signer les sessions (jetons JWT).
# Changez cette valeur pour une chaîne longue et aléatoire avant toute mise en production.
JWT_SECRET=change-moi-avec-une-longue-chaine-aleatoire

# Compte fondateur / administrateur créé automatiquement au premier démarrage
ADMIN_USERNAME=Mr Trafalgar D Water Law
ADMIN_EMAIL=fondateur@domaineofworld.cd
ADMIN_PASSWORD=Manasse$01

# Coordonnées de paiement affichées sur la page de certification (RDC)
PAY_ORANGE_NUMBER=+243 840 446 386
PAY_AIRTEL_NUMBER=+243 974 491 169
CERT_PRICE_USD=50

# Optionnel — uniquement utile en production avec un disque persistant.
# Si votre hébergeur monte un disque persistant à un chemin précis (ex: /var/data),
# indiquez-le ici pour que les comptes et fichiers ne soient jamais perdus.
# Laissez vide pour un usage local classique.
# DATA_DIR=/var/data
# UPLOAD_DIR=/var/data/uploads
